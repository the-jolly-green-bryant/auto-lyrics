<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- App Bar -->
    <LinearLayout
        android:id="@+id/layout_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface_dark"
        android:elevation="2dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="14dp"
            android:padding="8dp"
            android:src="@drawable/ic_lyrics"
            android:background="@drawable/bg_source_pill"
            android:contentDescription="@string/app_name" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto Lyrics"
            android:textColor="@color/on_surface"
            android:textSize="21sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tv_app_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live lyrics for Spotify"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Permission Status -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btn_permission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:text="Grant Notification Access"
        android:textAllCaps="false"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_panel"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btn_spotify"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect Spotify"
            android:textAllCaps="false"
            android:textColor="#07130B"
            android:textStyle="bold"
            android:backgroundTint="@color/spotify_green" />

        <TextView
            android:id="@+id/tv_spotify_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Spotify not connected"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_retry_lyrics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:text="Retry lyrics"
        android:textAllCaps="false"
        android:visibility="gone" />

    <!-- Track Info + Album Art + Source -->
    <LinearLayout
        android:id="@+id/layout_track_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_panel"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        android:padding="12dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_album_art"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_album_art" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_track"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface"
                android:textSize="17sp"
                android:textStyle="bold"
                android:lineSpacingExtra="3dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textColor="@color/spotify_green"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_source_pill"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Settings toggle row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|end"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btn_performance_mode"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Performance mode"
            android:textSize="11sp"
            android:textColor="@color/on_surface"
            android:backgroundTint="@color/surface_control"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textAllCaps="false"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginEnd="8dp"
            style="?attr/materialButtonOutlinedStyle" />

        <ImageButton
            android:id="@+id/btn_settings_toggle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Text settings"
            android:scaleType="centerInside"
            android:padding="6dp" />
    </LinearLayout>

    <!-- Font settings panel (collapsed by default) -->
    <LinearLayout
        android:id="@+id/layout_font_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_dark"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <!-- Font size row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Size"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_font_size_minus"
                android:layout_width="38dp"
                android:layout_height="34dp"
                android:text="A−"
                android:textSize="13sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textAllCaps="false"
                style="?attr/materialButtonOutlinedStyle" />

            <TextView
                android:id="@+id/tv_font_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:text="16sp"
                android:textColor="#CCCCDD"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:minWidth="48dp"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_font_size_plus"
                android:layout_width="38dp"
                android:layout_height="34dp"
                android:text="A+"
                android:textSize="13sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textAllCaps="false"
                style="?attr/materialButtonOutlinedStyle" />
        </LinearLayout>

        <!-- Font family row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_font_sans"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Sans"
                android:textSize="11sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#3A3A5E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_font_serif"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Serif"
                android:textSize="11sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="6dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_font_mono"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Mono"
                android:textSize="11sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="6dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_font_cursive"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Cursive"
                android:textSize="11sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="6dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle" />
        </LinearLayout>

        <!-- Android Auto section divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A3A"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android Auto"
            android:textColor="#8888AA"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <!-- AA Karaoke toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Karaoke Mode"
                android:textColor="#CCCCDD"
                android:textSize="13sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_aa_karaoke"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Translation toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Translate Lyrics"
                android:textColor="#CCCCDD"
                android:textSize="13sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_translation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- AA Delay row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AA Sync"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_aa_delay_minus"
                android:layout_width="38dp"
                android:layout_height="34dp"
                android:text="−"
                android:textSize="16sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textAllCaps="false"
                style="?attr/materialButtonOutlinedStyle" />

            <TextView
                android:id="@+id/tv_aa_delay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:text="0ms"
                android:textColor="#CCCCDD"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:minWidth="56dp"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_aa_delay_plus"
                android:layout_width="38dp"
                android:layout_height="34dp"
                android:text="+"
                android:textSize="16sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textAllCaps="false"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_aa_delay_reset"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Reset"
                android:textSize="10sp"
                android:textColor="#8888AA"
                android:backgroundTint="#222233"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="6dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                style="?attr/materialButtonOutlinedStyle" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20FFFFFF"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Lyrics -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/scroll_lyrics"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <TextView
                android:id="@+id/tv_lyrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="28dp"
                android:paddingBottom="40dp"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:lineSpacingExtra="8dp"
                android:fontFamily="sans-serif"
                android:gravity="center_horizontal"
                android:text="Play a song to see lyrics here.\n\nLyrics will also appear on Android Auto." />
        </ScrollView>

        <Button
            android:id="@+id/btn_jump_to_current"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="12dp"
            android:text="↓ Jump to Current"
            android:textSize="12sp"
            android:backgroundTint="@color/spotify_green"
            android:textColor="#07130B"
            android:elevation="6dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textAllCaps="false"
            android:minWidth="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone"
            style="?attr/materialButtonOutlinedStyle" />
    </FrameLayout>

    <!-- Delay Controls -->
    <LinearLayout
        android:id="@+id/layout_delay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_dark"
        android:elevation="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btn_previous_track"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="64dp"
                android:layout_height="48dp"
                android:backgroundTint="@color/surface_control"
                android:contentDescription="@string/previous_track"
                android:enabled="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="⏮"
                android:textAllCaps="false"
                android:textColor="@color/on_surface"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_next_track"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="64dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:backgroundTint="@color/surface_control"
                android:contentDescription="@string/next_track"
                android:enabled="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="⏭"
                android:textAllCaps="false"
                android:textColor="@color/on_surface"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_delay_minus"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="−"
                android:textSize="18sp"
                android:textColor="@color/on_surface"
                android:backgroundTint="@color/surface_control"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textAllCaps="false"
                style="?attr/materialButtonOutlinedStyle" />

            <TextView
                android:id="@+id/tv_delay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:text="Sync: 0ms"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:minWidth="100dp"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_delay_plus"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="18sp"
                android:textColor="@color/on_surface"
                android:backgroundTint="@color/surface_control"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textAllCaps="false"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_delay_reset"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Reset"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@color/surface_control"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="8dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle" />
        </LinearLayout>

        <!-- Sync tools row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="6dp">

            <Button
                android:id="@+id/btn_tap_sync"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Tap to Sync"
                android:textSize="11sp"
                android:textColor="#07130B"
                android:textStyle="bold"
                android:backgroundTint="@color/spotify_green"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                style="?attr/materialButtonOutlinedStyle" />
        </LinearLayout>

        <!-- Sync status (full-width below buttons for readability) -->
        <TextView
            android:id="@+id/tv_sync_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:textColor="#CCCCDD"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.2"
            android:visibility="gone" />

        <!-- Quick offset row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="4dp">

            <Button
                android:id="@+id/btn_quick_minus_1s"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="−1s"
                android:textSize="10sp"
                android:textColor="#AAAACC"
                android:backgroundTint="#222233"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_quick_minus_half"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="−0.5s"
                android:textSize="10sp"
                android:textColor="#AAAACC"
                android:backgroundTint="#222233"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="6dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_quick_plus_half"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="+0.5s"
                android:textSize="10sp"
                android:textColor="#AAAACC"
                android:backgroundTint="#222233"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="6dp"
