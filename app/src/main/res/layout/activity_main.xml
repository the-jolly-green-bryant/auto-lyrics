<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E2E"
        android:elevation="4dp"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto Lyrics"
            android:textColor="#E0E0FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Synced lyrics on Android Auto"
            android:textColor="#8888AA"
            android:textSize="14sp"
            android:paddingTop="4dp" />
    </LinearLayout>

    <!-- Permission Status -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btn_permission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:text="Grant Notification Access"
        android:textAllCaps="false"
        android:visibility="gone" />

    <!-- Track Info + Source -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_track"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:paddingEnd="80dp"
            android:textColor="#BB86FC"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|top"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="12dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textColor="#AAAACC"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_source_pill"
            android:visibility="gone" />
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A3A"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Lyrics -->
    <ScrollView
        android:id="@+id/scroll_lyrics"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <TextView
            android:id="@+id/tv_lyrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:textColor="#CCCCDD"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp"
            android:fontFamily="sans-serif"
            android:gravity="center_horizontal"
            android:text="Play a song to see lyrics here.\n\nLyrics will also appear on Android Auto." />
    </ScrollView>

    <!-- Delay Controls -->
    <LinearLayout
        android:id="@+id/layout_delay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#1A1A2A"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btn_delay_minus"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:text="−"
            android:textSize="18sp"
            android:textColor="#CCCCDD"
            android:backgroundTint="#2A2A3E"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:textAllCaps="false"
            style="?attr/materialButtonOutlinedStyle" />

        <TextView
            android:id="@+id/tv_delay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="Sync: 0ms"
            android:textColor="#8888AA"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:minWidth="100dp"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_delay_plus"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:text="+"
            android:textSize="18sp"
            android:textColor="#CCCCDD"
            android:backgroundTint="#2A2A3E"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:textAllCaps="false"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_delay_reset"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Reset"
            android:textSize="11sp"
            android:textColor="#8888AA"
            android:backgroundTint="#222233"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginStart="8dp"
            android:textAllCaps="false"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            style="?attr/materialButtonOutlinedStyle" />
    </LinearLayout>

</LinearLayout>
