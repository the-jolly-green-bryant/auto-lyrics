<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- App Bar -->
    <LinearLayout
        android:id="@+id/layout_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E2E"
        android:elevation="4dp"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto Lyrics"
            android:textColor="#E0E0FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tv_app_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Synced lyrics on Android Auto"
            android:textColor="#8888AA"
            android:textSize="14sp"
            android:paddingTop="4dp" />
    </LinearLayout>

    <!-- Permission Status -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btn_permission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:text="Grant Notification Access"
        android:textAllCaps="false"
        android:visibility="gone" />

    <!-- Track Info + Album Art + Source -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/iv_album_art"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_album_art" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_track"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#BB86FC"
                android:textSize="16sp"
                android:textStyle="bold"
                android:lineSpacingExtra="3dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textColor="#AAAACC"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_source_pill"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Settings toggle row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|end"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <ImageButton
            android:id="@+id/btn_settings_toggle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Text settings"
            android:scaleType="centerInside"
            android:padding="6dp" />
    </LinearLayout>

    <!-- Font settings panel (collapsed by default) -->
    <LinearLayout
        android:id="@+id/layout_font_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A2A"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <!-- Font size row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Size"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_font_size_minus"
                android:layout_width="38dp"
                android:layout_height="34dp"
                android:text="A−"
                android:textSize="13sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textAllCaps="false"
                style="?attr/materialButtonOutlinedStyle" />

            <TextView
                android:id="@+id/tv_font_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:text="16sp"
                android:textColor="#CCCCDD"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:minWidth="48dp"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_font_size_plus"
                android:layout_width="38dp"
                android:layout_height="34dp"
                android:text="A+"
                android:textSize="13sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:textAllCaps="false"
                style="?attr/materialButtonOutlinedStyle" />
        </LinearLayout>

        <!-- Font family row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_font_sans"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Sans"
                android:textSize="11sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#3A3A5E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_font_serif"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Serif"
                android:textSize="11sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="6dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_font_mono"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Mono"
                android:textSize="11sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="6dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btn_font_cursive"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Cursive"
                android:textSize="11sp"
                android:textColor="#CCCCDD"
                android:backgroundTint="#2A2A3E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="6dp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A3A"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Lyrics -->
    <ScrollView
        android:id="@+id/scroll_lyrics"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <TextView
            android:id="@+id/tv_lyrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:textColor="#CCCCDD"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp"
            android:fontFamily="sans-serif"
            android:gravity="center_horizontal"
            android:text="Play a song to see lyrics here.\n\nLyrics will also appear on Android Auto." />
    </ScrollView>

    <!-- Delay Controls -->
    <LinearLayout
        android:id="@+id/layout_delay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#1A1A2A"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btn_delay_minus"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:text="−"
            android:textSize="18sp"
            android:textColor="#CCCCDD"
            android:backgroundTint="#2A2A3E"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:textAllCaps="false"
            style="?attr/materialButtonOutlinedStyle" />

        <TextView
            android:id="@+id/tv_delay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="Sync: 0ms"
            android:textColor="#8888AA"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:minWidth="100dp"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_delay_plus"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:text="+"
            android:textSize="18sp"
            android:textColor="#CCCCDD"
            android:backgroundTint="#2A2A3E"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:textAllCaps="false"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_delay_reset"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Reset"
            android:textSize="11sp"
            android:textColor="#8888AA"
            android:backgroundTint="#222233"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginStart="8dp"
            android:textAllCaps="false"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            style="?attr/materialButtonOutlinedStyle" />
    </LinearLayout>

</LinearLayout>
